# Auth.js cookie encryption secret. Generate with: openssl rand -base64 32
AUTH_SECRET=

# Your account is created on first launch at http://localhost:3000/setup.
# No username/password env vars needed.

# Optional pre-seed for the Anthropic API key. Leave blank and paste the key
# into Settings → Credentials after first sign-in.
ANTHROPIC_API_KEY=

# SQLite database file. Will be created on first run.
DATABASE_PATH=./data/boardroom.db

# Unix domain socket for Next.js ↔ agent worker IPC.
AGENT_WORKER_SOCKET=./.agent.sock

# Terminal WebSocket port and bind address.
AGENT_WORKER_WS_PORT=9099
# AGENT_WORKER_WS_HOST=0.0.0.0

# Server port
PORT=3000
NODE_ENV=development

# Set this to your public URL when deploying behind HTTPS.
# NEXTAUTH_URL=https://boardroom.example.com

# ============================================================================
# OIDC SSO (optional — Google, Authentik, Keycloak, etc.)
# ============================================================================
# OIDC_ISSUER_URL=
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_REDIRECT_URI=http://localhost:3000/api/auth/callback/oidc
# ALLOWED_OIDC_SUBJECT=
# ALLOWED_OIDC_EMAIL=
