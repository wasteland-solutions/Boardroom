# Anthropic API key used by the Claude Agent SDK worker.
# Only required when Settings → Authentication is set to "Anthropic API key".
# If you pick "Claude Code login" in Settings, leave this empty and run
# `claude login` on the host so the Claude Code CLI can use its own OAuth
# token (billed to your Claude Max / Pro subscription).
ANTHROPIC_API_KEY=

# SQLite database file. Will be created on first run.
DATABASE_PATH=./data/boardroom.db

# Unix domain socket (or Windows named pipe path) for Next.js ↔ agent worker IPC.
# On Windows use something like: \\.\pipe\boardroom-agent
AGENT_WORKER_SOCKET=./.agent.sock

# --- OIDC SSO (single user) ---
# Any standards-compliant OIDC issuer (Google, Authentik, Keycloak, etc.).
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
# Must match the redirect URI registered with your provider.
# Typically: http://localhost:3000/api/auth/callback/oidc
OIDC_REDIRECT_URI=http://localhost:3000/api/auth/callback/oidc

# Exactly ONE of these must be set — the only user allowed to sign in.
ALLOWED_OIDC_SUBJECT=
ALLOWED_OIDC_EMAIL=

# Auth.js cookie encryption secret. Generate with: openssl rand -base64 32
AUTH_SECRET=

# Server port
PORT=3000
NODE_ENV=development
