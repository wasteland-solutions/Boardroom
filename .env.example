# Optional pre-seed for the Anthropic API key. Leave blank and paste the key
# into Settings → Credentials after first sign-in. If both are set, the value
# from Settings takes precedence.
ANTHROPIC_API_KEY=

# SQLite database file. Will be created on first run.
DATABASE_PATH=./data/boardroom.db

# Unix domain socket (or Windows named pipe path) for Next.js ↔ agent worker IPC.
# On Windows use something like: \\.\pipe\boardroom-agent
AGENT_WORKER_SOCKET=./.agent.sock

# Port for the terminal WebSocket endpoint served by the agent worker. The
# browser connects to this directly (with a short-lived HMAC token minted
# by the Next.js side). Make sure this is exposed in docker-compose.yml.
AGENT_WORKER_WS_PORT=8099

# Host/interface for the terminal WebSocket to bind to. Defaults to 127.0.0.1
# (loopback only). Set to 0.0.0.0 in Docker to expose within the container network.
# AGENT_WORKER_WS_HOST=127.0.0.1

# ============================================================================
# Sign-in
# ============================================================================
# Pick ONE or BOTH of the two options below. If you enable both, the sign-in
# page will show both — username/password on top, SSO below.

# ---- Option A: username + password (simplest) ----
# Set both to enable. The sign-in page will show a username/password form.
# The password is compared in constant time. This is fine for a single-user
# self-host where you already trust .env.
BOARDROOM_USERNAME=
BOARDROOM_PASSWORD=

# ---- Option B: OIDC SSO (Google, Authentik, Keycloak, …) ----
# Set all four to enable. Uses discovery via ${OIDC_ISSUER_URL}/.well-known/openid-configuration.
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
# Typically: http://localhost:3000/api/auth/callback/oidc
OIDC_REDIRECT_URI=http://localhost:3000/api/auth/callback/oidc

# Exactly ONE of these must be set when using OIDC — the only identity allowed to sign in.
ALLOWED_OIDC_SUBJECT=
ALLOWED_OIDC_EMAIL=

# ---- Shared ----
# Auth.js cookie encryption secret. Generate with: openssl rand -base64 32
AUTH_SECRET=

# Server port
PORT=3000
NODE_ENV=development

# Set this to your public URL when deploying behind HTTPS. Required for
# auth cookies to have the Secure flag set.
# NEXTAUTH_URL=https://boardroom.example.com
