{
  "name": "boardroom",
  "version": "0.1.0",
  "private": true,
  "description": "A DM with Claude Code — single-user web app that bridges to Claude Code via the Claude Agent SDK.",
  "scripts": {
    "dev": "concurrently -k -n next,agent -c blue,magenta \"next dev\" \"tsx watch src/agent/worker.ts\"",
    "build": "next build && tsc -p src/agent/tsconfig.json",
    "start": "node scripts/start.mjs",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "postinstall": "node scripts/fix-node-pty.mjs"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.9",
    "@anthropic-ai/claude-code": "^2.1.98",
    "@openai/codex": "^0.118.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "better-sqlite3": "^11.7.0",
    "drizzle-orm": "^0.38.0",
    "next": "15.5.15",
    "next-auth": "5.0.0-beta.25",
    "node-pty": "^1.1.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "ws": "^8.20.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.2",
    "@types/react": "19.0.2",
    "@types/react-dom": "19.0.2",
    "@types/ws": "^8.18.1",
    "concurrently": "^9.1.0",
    "drizzle-kit": "^0.30.1",
    "eslint": "^9.17.0",
    "eslint-config-next": "15.5.15",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
